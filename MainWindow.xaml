<Window
    x:Class="PriorityPulse.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="PriorityPulse">

    <Grid x:Name="RootGrid">
        <Grid.Resources>
            <Style TargetType="TextBlock">
                <Setter Property="FontFamily" Value="Segoe UI Variable Display"/>
            </Style>
            <Style TargetType="NavigationViewItem">
                <Setter Property="FontFamily" Value="Segoe UI Variable Display"/>
            </Style>

            <!-- macOS-style window control dots -->
            <Style x:Key="MacDotStyle" TargetType="Button">
                <Setter Property="Width"  Value="12"/>
                <Setter Property="Height" Value="12"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="CornerRadius" Value="6"/>
                <Setter Property="MinWidth"  Value="0"/>
                <Setter Property="MinHeight" Value="0"/>
                <Setter Property="UseSystemFocusVisuals" Value="False"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Root"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="{TemplateBinding CornerRadius}"
                                    Width="{TemplateBinding Width}"
                                    Height="{TemplateBinding Height}">
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal"/>
                                        <VisualState x:Name="PointerOver">
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="Root"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 To="0.65" Duration="0:0:0.1"/>
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="Pressed">
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="Root"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 To="0.4" Duration="0:0:0.05"/>
                                            </Storyboard>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title bar with dot controls (right-aligned: minimize, maximize, close) -->
        <Grid x:Name="AppTitleBar" Grid.Row="0">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="0,0,16,0" Spacing="8">
                <Button Style="{StaticResource MacDotStyle}" Background="#FEBC2E"
                        Click="TitleMinBtn_Click"   ToolTipService.ToolTip="Minimize"/>
                <Button Style="{StaticResource MacDotStyle}" Background="#28C840"
                        Click="TitleMaxBtn_Click"   ToolTipService.ToolTip="Maximize"/>
                <Button Style="{StaticResource MacDotStyle}" Background="#FF5F57"
                        Click="TitleCloseBtn_Click" ToolTipService.ToolTip="Close"/>
            </StackPanel>
        </Grid>

        <!-- Navigation sidebar -->
        <NavigationView x:Name="AppNavView" Grid.Row="1"
                        PaneDisplayMode="LeftCompact"
                        IsBackButtonVisible="Collapsed"
                        IsSettingsVisible="False"
                        IsPaneToggleButtonVisible="True"
                        CompactModeThresholdWidth="600"
                        ExpandedModeThresholdWidth="1000"
                        SelectionChanged="AppNavView_SelectionChanged">

            <NavigationView.Resources>
                <SolidColorBrush x:Key="NavigationViewContentBackground"                Color="Transparent"/>
                <SolidColorBrush x:Key="NavigationViewItemBackgroundPointerOver"        Color="#15FFFFFF"/>
                <SolidColorBrush x:Key="NavigationViewItemBackgroundPressed"             Color="#08FFFFFF"/>
                <SolidColorBrush x:Key="NavigationViewItemBackgroundSelected"            Color="#1AFFFFFF"/>
                <SolidColorBrush x:Key="NavigationViewItemBackgroundSelectedPointerOver" Color="#20FFFFFF"/>
            </NavigationView.Resources>

            <NavigationView.PaneHeader>
                <StackPanel Margin="16,10,12,20" Spacing="4">
                    <TextBlock x:Name="AppTitleText" Text="PriorityPulse"
                               FontSize="22" FontWeight="SemiBold"/>
                    <TextBlock x:Name="AppSubtitleText"
                               Text="Lightweight, automatic process priority control"
                               FontSize="11" Opacity="0.6" TextWrapping="Wrap"/>
                </StackPanel>
            </NavigationView.PaneHeader>

            <NavigationView.MenuItems>
                <NavigationViewItem Content="Target App" Tag="TargetApp" Icon="Play"/>
                <NavigationViewItem Content="Console"    Tag="Console"   Icon="Document"/>
                <NavigationViewItem Content="Settings"   Tag="Settings"  Icon="Setting"/>
            </NavigationView.MenuItems>

            <!-- Page content area -->
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid Padding="30">
                    <StackPanel Spacing="20">
                        <StackPanel Spacing="6">
                            <TextBlock x:Name="PageTitleText" Text="Target App"
                                       FontSize="32" FontWeight="SemiBold"/>
                            <TextBlock x:Name="PageSubtitleText"
                                       Text="Choose which executables PriorityPulse should monitor."
                                       FontSize="13" Opacity="0.7"/>
                        </StackPanel>
                        <StackPanel x:Name="PageContentHost" Spacing="18">
                            <StackPanel.RenderTransform>
                                <TranslateTransform x:Name="PageContentTransform"/>
                            </StackPanel.RenderTransform>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </NavigationView>
    </Grid>
</Window>
